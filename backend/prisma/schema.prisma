generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String    @id @default(uuid())
  nome        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  groups      Group[]
  createdBy   User?     @relation("OrganizationCreator", fields: [createdById], references: [id])
  users       User[]

  @@index([deletedAt])
}

model User {
  id             String         @id @default(uuid())
  nome           String
  email          String         @unique
  senha          String
  role           Role
  organizationId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  createdGroups  Group[]        @relation("GroupCreator")
  createdOrgs    Organization[] @relation("OrganizationCreator")
  transactions   Transaction[]  @relation("UserTransactions")
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  groups         UserGroup[]

  @@index([deletedAt])
}

model Group {
  id             String        @id @default(uuid())
  nome           String
  saldoInicial   Decimal?      @map("saldo_inicial") @db.Decimal(10, 2)
  organizationId String        @map("organization_id")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  leaderName     String?
  createdById    String?
  createdBy      User?         @relation("GroupCreator", fields: [createdById], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  users          UserGroup[]

  @@index([organizationId])
}

model UserGroup {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  groupId    String          @map("group_id")
  permission GroupPermission
  createdAt  DateTime        @default(now())
  createdBy  String?         @map("created_by")
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Transaction {
  id          String          @id @default(uuid())
  groupId     String          @map("group_id")
  type        TransactionType
  valor       Decimal         @db.Decimal(10, 2)
  descricao   String
  paymentType PaymentType?    @map("payment_type")
  data        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?         @map("created_by")
  user        User?           @relation("UserTransactions", fields: [createdBy], references: [id])
  group       Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([createdBy])
  @@index([paymentType])
  @@index([type])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  LIDER
  MEMBRO
}

enum GroupPermission {
  READ_ONLY
  EDITOR
}

enum TransactionType {
  ENTRADA
  SAIDA
}

enum PaymentType {
  PIX
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  TRANSFERENCIA
}
