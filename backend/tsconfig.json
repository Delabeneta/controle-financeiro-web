{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",

    "outDir": "./dist",
    "rootDir": "./",

    "baseUrl": "./",
    "paths": {
      "src/*": ["src/*"]
    },

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "sourceMap": true,
    "declaration": true,
    "removeComments": true,

    "incremental": true,
    "skipLibCheck": true,

    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,

    "noImplicitAny": false,

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },
    "include": ["src/**/*", "prisma.config.ts"], 
    "exclude": [
    "node_modules",
    "test",
    "**/*.spec.ts"],
  "ignoreDeprecations": "6.0"
}